# ─── Supabase ─────────────────────────────────────────────────
# Obtenha em: https://supabase.com/dashboard/project/_/settings/api
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# SERVICE ROLE KEY — NUNCA exponha no frontend
# Usada apenas pelo servidor Express (server/index.ts)
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Segurança ────────────────────────────────────────────────
# Chave de acesso aos endpoints administrativos da API
# Gere com: openssl rand -hex 32
ADMIN_KEY=gere-uma-chave-forte-aqui

# Chave de acesso admin no frontend (painel do colaborador)
# Deve ser IGUAL ao ADMIN_KEY acima
VITE_ADMIN_KEY=gere-uma-chave-forte-aqui

# ─── Servidor ─────────────────────────────────────────────────
PORT=4000
NODE_ENV=production

# ─── n8n Webhook ──────────────────────────────────────────────
# URL do webhook n8n para receber eventos (leads, simulações, contatos)
N8N_WEBHOOK_URL=https://n8n.destrava.permupay.com.br/webhook/destrava

# ─── WhatsApp / Baileys ───────────────────────────────────────
# URL da API do Baileys (se usar serviço separado)
BAILEYS_API_URL=http://localhost:3001
BAILEYS_API_KEY=sua-chave-baileys-aqui

# ─── Chatwoot ─────────────────────────────────────────────────
CHATWOOT_URL=https://chatwoot.destrava.permupay.com.br
CHATWOOT_API_TOKEN=seu-token-chatwoot-aqui
CHATWOOT_ACCOUNT_ID=1

# ─── OpenAI / LLM ─────────────────────────────────────────────
OPENAI_API_KEY=sk-...
# Modelo padrão para agentes de IA
OPENAI_MODEL=gpt-4.1-mini

# ─── Email (opcional) ─────────────────────────────────────────
# Para notificações por email via n8n ou serviço externo
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=contato@destravacredito.com.br
SMTP_PASS=sua-senha-de-app-aqui

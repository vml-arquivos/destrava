
# SERVICE ROLE KEY — NUNCA exponha no frontend
# Usada apenas pelo servidor Express (server/index.ts)

# ─── Segurança ────────────────────────────────────────────────
# Segredo usado para assinatura e validação de tokens JWT
# Gere com: openssl rand -hex 48
JWT_SECRET=gere-uma-chave-forte-com-openssl-rand-hex-48

# ─── Servidor ─────────────────────────────────────────────────
PORT=4000
NODE_ENV=production

# ─── n8n Webhook ──────────────────────────────────────────────
# URL do webhook n8n para receber eventos (leads, simulações, contatos)
N8N_WEBHOOK_URL=https://n8n.destrava.permupay.com.br/webhook/destrava

# ─── WhatsApp / Baileys ───────────────────────────────────────
# URL da API do Baileys (se usar serviço separado)
BAILEYS_API_URL=http://localhost:3001
BAILEYS_API_KEY=sua-chave-baileys-aqui

# ─── Chatwoot ─────────────────────────────────────────────────
CHATWOOT_URL=https://chatwoot.destrava.permupay.com.br
CHATWOOT_API_TOKEN=seu-token-chatwoot-aqui
CHATWOOT_ACCOUNT_ID=1

# ─── OpenAI / LLM ─────────────────────────────────────────────
OPENAI_API_KEY=sk-...
# Modelo padrão para agentes de IA
OPENAI_MODEL=gpt-4.1-mini

# ─── Email (opcional) ─────────────────────────────────────────
# Para notificações por email via n8n ou serviço externo
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=contato@destravacredito.com.br
SMTP_PASS=sua-senha-de-app-aqui

# ─── Banco de Dados (PostgreSQL nativo na VPS) ───────────────────────────────
DATABASE_URL=postgres://postgres:SENHA@postgresql-database:5432/postgres


# ─── Microsserviço de Previsão de Faturamento (Python/FastAPI) ───────────────
# URL do microsserviço Docker separado (ver services/predicao-faturamento/)
PREDICAO_SERVICE_URL=http://localhost:8001

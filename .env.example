
# SERVICE ROLE KEY — NUNCA exponha no frontend
# Usada apenas pelo servidor Express (server/index.ts)

# ─── Segurança ────────────────────────────────────────────────
# Segredo usado para assinatura e validação de tokens JWT
# Gere com: openssl rand -hex 48
JWT_SECRET=gere-uma-chave-forte-com-openssl-rand-hex-48

# ─── Servidor ─────────────────────────────────────────────────
PORT=4000
NODE_ENV=production
FRONTEND_URL=https://destravacredito.com

# ─── n8n Webhook ──────────────────────────────────────────────
# URL do webhook n8n para receber eventos gerais (leads, simulações, contatos)
N8N_WEBHOOK_URL=https://n8n.destrava.permupay.com.br/webhook/destrava

# ─── Nexus/n8n — Inteligência 360 / Tarefas de Pendências (Sprint 7/8) ────
# Ativa o botão "Criar tarefa no Nexus" na aba Inteligência 360.
# Configure pelo menos uma das URLs abaixo para habilitar a integração.
# Se NEXUS_WEBHOOK_URL estiver definida, ela tem prioridade.
# O envio só ocorre com confirmação explícita do usuário e validação server-side.
#
# URL do webhook do Nexus para receber tarefas de pendências críticas
NEXUS_WEBHOOK_URL=
# Token de autenticação Bearer para o Nexus (opcional, mas recomendado)
NEXUS_API_TOKEN=
# N8N_WEBHOOK_URL acima também serve como fallback para tarefas do Nexus.
# Não é necessário duplicar se já estiver definida acima.

# ─── WhatsApp / Baileys ───────────────────────────────────────
# URL da API do Baileys (se usar serviço separado)
BAILEYS_API_URL=http://localhost:3001
BAILEYS_API_KEY=sua-chave-baileys-aqui

# ─── Chatwoot ─────────────────────────────────────────────────
CHATWOOT_URL=https://chatwoot.destrava.permupay.com.br
CHATWOOT_API_TOKEN=seu-token-chatwoot-aqui
CHATWOOT_ACCOUNT_ID=1

# ─── OpenAI / LLM ─────────────────────────────────────────────
OPENAI_API_KEY=sk-...
# Modelo padrão para agentes de IA
OPENAI_MODEL=gpt-4.1-mini

# ─── Email (opcional) ─────────────────────────────────────────
# Para notificações por email via n8n ou serviço externo
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=contato@destravacredito.com.br
SMTP_PASS=sua-senha-de-app-aqui

# ─── Banco de Dados (PostgreSQL nativo na VPS) ───────────────────────────────
DATABASE_URL=postgres://postgres:SENHA@postgresql-database:5432/postgres


# ─── Microsserviço de Previsão de Faturamento (Python/FastAPI) ───────────────
# URL do microsserviço Docker separado (ver services/predicao-faturamento/)
PREDICAO_SERVICE_URL=http://localhost:8001

# Integração Destrava ↔ Nexus
NEXUS_INTEGRATION_SECRET=troque-por-uma-chave-forte-igual-nos-dois-sistemas
NEXUS_PUBLIC_URL=https://nexus.permupay.com.br

# ─── Automation Engine (Destrava ↔ Nexus) ─────────────────────
# Reaproveita NEXUS_INTEGRATION_SECRET acima como chave de assinatura HMAC.
# Intervalos opcionais do scheduler (ms) -- os padrões já cobrem uso normal.
AUTOMATION_RETRY_INTERVAL_MS=60000
AUTOMATION_ROTINAS_INTERVAL_MS=900000

# ─── CPFHub.io / consulta cadastral de CPF de sócios ───────────────
# Chave privada. Não expor no frontend e não versionar .env real.
CPFHUB_API_KEY=sua-chave-cpfhub-aqui
CPFHUB_API_URL=https://api.cpfhub.io
CPFHUB_TIMEOUT_MS=10000

# CPF.CNPJ - QSA com CPF completo dos sócios
CPFCNPJ_ENABLED=true
CPFCNPJ_TOKEN=
CPFCNPJ_API_URL=https://api.cpfcnpj.com.br
CPFCNPJ_CNPJ_PACKAGE=6
CPFCNPJ_TIMEOUT_MS=60000

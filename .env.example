# ─── Destrava Crédito - Variáveis de Ambiente ───────────────────────────────
# Configure estas variáveis no painel do Coolify em:
# Application > Environment Variables

# Ambiente (sempre production no Coolify)
NODE_ENV=production

# Porta interna do container
# IMPORTANTE: Usar 4000 para não conflitar com Chatwoot (porta 3000)
# O Traefik roteia destrava.permupay.com.br → container:4000 automaticamente
PORT=4000

# Diretório para persistência de dados (leads, simulações, contatos)
# No Coolify: adicione um Volume persistente mapeado para /var/data/destrava
DATA_DIR=/var/data/destrava

# Chave de acesso ao painel admin (TROQUE ANTES DO DEPLOY!)
# Acesso: GET /api/leads com header x-admin-key: SUA_CHAVE
ADMIN_KEY=destrava2024admin

# Domínio do site
SITE_DOMAIN=destrava.permupay.com.br

# WhatsApp para atendimento
WHATSAPP_NUMBER=5561986055223

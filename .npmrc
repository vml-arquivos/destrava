# Garante que pacotes usados internamente pelo React (scheduler, react-dom)
# tenham symlinks em node_modules raiz, permitindo que o Vite/Rollup
# os resolva corretamente durante o build de produção.
# Sem isso, "scheduler" fica apenas em node_modules/.pnpm/... e o Rollup
# o trata como módulo externo, causando erro no browser:
# "Failed to resolve module specifier scheduler"
public-hoist-pattern[]=scheduler
public-hoist-pattern[]=react
public-hoist-pattern[]=react-dom
public-hoist-pattern[]=react/jsx-runtime

      "position": [-800, 400],
      "id": "crm-historico-001",
      "name": "Buscar histórico conversa",
      "credentials": { "postgres": { "id": "g7IUIrtqmqAM3wCr", "name": "Postgres account" } }
    },
    {
      "parameters": {
        "jsCode": "// Montar prompt completo para o LLM\nconst historico = $input.all();\nconst info = $('Info').first().json;\n\n// Dados do lead\nlet leadData = {};\ntry { leadData = $('Buscar Lead no CRM').first().json || {}; } catch(e) {}\ntry { if (!leadData.id) leadData = $('Criar Lead no CRM').first().json || {}; } catch(e) {}\n\n// Formatar histórico\nconst msgs = historico\n  .map(h => {\n    try {\n      const m = typeof h.json.message === 'string' ? JSON.parse(h.json.message) : h.json.message;\n      const role = m.type === 'ai' ? 'Consultor' : 'Cliente';\n      return `${role}: ${m.content || m.text || ''}`;\n    } catch(e) { return ''; }\n  })\n  .filter(Boolean)\n  .reverse()\n  .join('\\n');\n\nconst prompt = `Analise o lead abaixo e retorne um JSON estruturado de qualificação.\\n\\n## DADOS DO LEAD\\n- Nome: ${leadData.nome || info.nome_contato || 'Desconhecido'}\\n- Telefone: ${info.telefone}\\n- Empresa: ${leadData.empresa || 'Não informado'}\\n- Produto de interesse: ${leadData.produto_interesse || 'Não identificado'}\\n- Valor solicitado: ${leadData.valor_solicitado || 'Não informado'}\\n- Etapa atual: ${leadData.etapa_funil || 'novo'}\\n- Temperatura atual: ${leadData.temperatura || 'frio'}\\n\\n## HISTÓRICO DA CONVERSA (últimas 20 mensagens)\\n${msgs || 'Sem histórico ainda.'}\\n\\n## ÚLTIMA MENSAGEM RECEBIDA\\n${info.mensagem}\\n\\n---\\n\\nRetorne APENAS um JSON válido com esta estrutura exata (sem markdown, sem explicação):\\n{\\n  \\\"score\\\": <0-100>,\\n  \\\"temperatura\\\": <\\\"frio\\\"|\\\"morno\\\"|\\\"quente\\\"|\\\"urgente\\\">,\\n  \\\"etapa_sugerida\\\": <\\\"novo\\\"|\\\"contato_feito\\\"|\\\"qualificado\\\"|\\\"proposta_enviada\\\"|\\\"negociacao\\\"|\\\"documentacao\\\"|\\\"aprovacao\\\">,\\n  \\\"probabilidade_conversao\\\": <0-100>,\\n  \\\"resumo\\\": \\\"<resumo objetivo em 1-2 frases>\\\",\\n  \\\"proxima_acao\\\": \\\"<ação específica para o consultor>\\\",\\n  \\\"pontos_positivos\\\": [\\\"<ponto1>\\\"],\\n  \\\"pontos_atencao\\\": [\\\"<ponto1>\\\"],\\n  \\\"documentos_faltando\\\": [\\\"<doc1>\\\"],\\n  \\\"nome_identificado\\\": \\\"<nome real ou null>\\\",\\n  \\\"empresa_identificada\\\": \\\"<empresa ou null>\\\",\\n  \\\"produto_identificado\\\": \\\"<produto ou null>\\\",\\n  \\\"valor_identificado\\\": <numero ou null>,\\n  \\\"prazo_identificado\\\": <meses ou null>\\n}\\n\\nScore: 0-25=frio | 26-50=morno | 51-75=quente | 76-100=urgente`;\n\nreturn [{\n  json: {\n    lead_id: leadData.id,\n    telefone: info.telefone,\n    event_id_unico: info.event_id_unico,\n    prompt\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [-560, 400],
      "id": "crm-montar-prompt-001",
      "name": "Montar prompt"
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "={{ $json.prompt }}",
        "options": {
          "systemMessage": "Você é um especialista em qualificação de leads de crédito empresarial e pessoal. Analise conversas de WhatsApp e retorne APENAS JSON válido, sem markdown, sem explicação adicional."
        }
      },
      "type": "@n8n/n8n-nodes-langchain.chainLlm",
      "typeVersion": 1.4,
      "position": [-320, 400],
      "id": "crm-llm-chain-001",
      "name": "Qualificar com Gemini"
    },
    {
      "parameters": {
        "modelName": "models/gemini-2.5-flash",
        "options": {
          "temperature": 0.1,
          "maxOutputTokens": 1024
        }
      },
      "type": "@n8n/n8n-nodes-langchain.lmChatGoogleGemini",
      "typeVersion": 1,
      "position": [-320, 580],
      "id": "crm-gemini-001",
      "name": "Gemini 2.5 Flash",
      "credentials": { "googlePalmApi": { "id": "utglXGgdfvIxw8T7", "name": "gemini-ia" } }
    },
    {
      "parameters": {
        "jsCode": "// Parsear o JSON retornado pelo LLM\nconst output = $json.text || $json.output || $json.message || '';\nconst contexto = $('Montar prompt').first().json;\n\nlet q = {};\ntry {\n  const match = output.match(/\\{[\\s\\S]*\\}/);\n  q = JSON.parse(match ? match[0] : output);\n} catch(e) {\n  q = {\n    score: 10, temperatura: 'frio', etapa_sugerida: 'novo',\n    probabilidade_conversao: 10,\n    resumo: 'Análise automática indisponível.',\n    proxima_acao: 'Revisar conversa manualmente.',\n    pontos_positivos: [], pontos_atencao: ['Erro no processamento'],\n    documentos_faltando: [],\n    nome_identificado: null, empresa_identificada: null,\n    produto_identificado: null, valor_identificado: null, prazo_identificado: null\n  };\n}\n\nreturn [{ json: { ...q, lead_id: contexto.lead_id, telefone: contexto.telefone, event_id_unico: contexto.event_id_unico } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [-80, 400],
      "id": "crm-parsear-json-001",
      "name": "Parsear JSON"
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT public.crm_atualizar_qualificacao(\n  '{{ $json.lead_id }}'::uuid,\n  {{ $json.score }}::integer,\n  '{{ $json.temperatura }}',\n  '{{ $json.etapa_sugerida }}',\n  '{{ ($json.resumo || '').replace(/'/g, \"''\") }}',\n  '{{ ($json.proxima_acao || '').replace(/'/g, \"''\") }}',\n  ARRAY[{{ ($json.documentos_faltando || []).map(d => \"'\" + String(d).replace(/'/g, \"''\") + \"'\").join(',') || \"''\" }}]::text[],\n  {{ $json.probabilidade_conversao || 0 }}::integer,\n  ARRAY[{{ ($json.pontos_positivos || []).map(p => \"'\" + String(p).replace(/'/g, \"''\") + \"'\").join(',') || \"''\" }}]::text[],\n  ARRAY[{{ ($json.pontos_atencao || []).map(p => \"'\" + String(p).replace(/'/g, \"''\") + \"'\").join(',') || \"''\" }}]::text[]\n) as qualificacao_id;",
        "options": {}
      },

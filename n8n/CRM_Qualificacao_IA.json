    {
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO crm_conversas (lead_id, canal, canal_id_externo, status)\nSELECT\n  l.id,\n  'whatsapp',\n  '{{ $('Info').item.json.id_conversa }}',\n  'aberta'\nFROM leads l\nWHERE l.telefone = '{{ $('Info').item.json.telefone }}'\nON CONFLICT (canal_id_externo) DO UPDATE\n  SET ultima_interacao_em = NOW()\nRETURNING id as conversa_id, lead_id;",
